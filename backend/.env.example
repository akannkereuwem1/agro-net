# Development Database Configuration
DB_NAME=agronet_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Interswitch Payment Gateway
INTERSWITCH_BASE_URL=https://sandbox.interswitchng.com
INTERSWITCH_CLIENT_ID=your_client_id
INTERSWITCH_CLIENT_SECRET=your_client_secret

# AI Price Prediction — TensorFlow/Keras model configuration
# Path to the trained Keras model file used for price prediction inference.
# Defaults to "ai/model/price_model.keras" if not set.
AI_MODEL_PATH=ai/model/price_model.keras

# Version tag recorded on every PricePrediction record for traceability.
# Defaults to "v1.0" if not set.
AI_MODEL_VERSION=v1.0

# Google Cloud Vision API — Image Classification
# Absolute path to the Google service account JSON credentials file.
# Required — ClassificationService raises VisionAPIConfigError if absent.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
